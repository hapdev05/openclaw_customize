     \"allowFrom\": [\n        \"7835139312\"\n      ],\n      \"botToken\": \"8195629281:AAG7BNlTQA9QAdjoM4qGog9e5VA39E4KTig\",\n      \"groupPolicy\": \"open\",\n      \"groupAllowFrom\": [\n        \"*\"\n      ],\n      \"groups\": {\n        \"*\": {\n          \"groupPolicy\": \"open\",\n          \"requireMention\": false\n        }\n      },\n      \"streaming\": \"partial\"\n    }"},"partialJson":"{\"file_path\":\"C:\\\\Users\\\\admin\\\\.openclaw\\\\openclaw.json\",\"old_string\":\"    \\\"telegram\\\": {\\n      \\\"enabled\\\": true,\\n      \\\"dmPolicy\\\": \\\"pairing\\\",\\n      \\\"botToken\\\": \\\"8195629281:AAG7BNlTQA9QAdjoM4qGog9e5VA39E4KTig\\\",\\n      \\\"groupPolicy\\\": \\\"open\\\",\\n      \\\"streaming\\\": \\\"partial\\\"\\n    }\",\"new_string\":\"    \\\"telegram\\\": {\\n      \\\"enabled\\\": true,\\n      \\\"dmPolicy\\\": \\\"pairing\\\",\\n      \\\"allowFrom\\\": [\\n        \\\"7835139312\\\"\\n      ],\\n      \\\"botToken\\\": \\\"8195629281:AAG7BNlTQA9QAdjoM4qGog9e5VA39E4KTig\\\",\\n      \\\"groupPolicy\\\": \\\"open\\\",\\n      \\\"groupAllowFrom\\\": [\\n        \\\"*\\\"\\n      ],\\n      \\\"groups\\\": {\\n        \\\"*\\\": {\\n          \\\"groupPolicy\\\": \\\"open\\\",\\n          \\\"requireMention\\\": false\\n        }\\n      },\\n      \\\"streaming\\\": \\\"partial\\\"\\n    }\"}"}],"api":"openai-codex-responses","provider":"openai-codex","model":"gpt-5.4","usage":{"input":8614,"output":624,"cacheRead":18432,"cacheWrite":0,"totalTokens":27670,"cost":{"input":0.021535000000000002,"output":0.00936,"cacheRead":0.004608,"cacheWrite":0,"total":0.035503}},"stopReason":"toolUse","timestamp":1774237795258}}
