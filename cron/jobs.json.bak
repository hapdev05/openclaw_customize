{
  "version": 1,
  "jobs": [
    {
      "id": "whitepaper-daily-sync",
      "schedule": {
        "kind": "cron",
        "expr": "0 20 * * *"
      },
      "prompt": "Read the skill file `workspace/skills/whitepaper-sync/SKILL.md` and follow its sync process. Fetch all whitepaper pages listed in the skill, summarize their content, and update `workspace/memory/whitepaper-data.md` with any new or changed information. Log results in today's `workspace/memory/YYYY-MM-DD.md`.",
      "enabled": true,
      "state": {
        "nextRunAtMs": 1774962000000
      },
      "name": "Cron: 0 20 * * *",
      "wakeMode": "now",
      "sessionTarget": "main"
    }
  ]
}